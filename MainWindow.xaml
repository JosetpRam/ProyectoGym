<Window x:Class="ProyectoGym.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProyectoGym"
        mc:Ignorable="d"
        Title="MainWindow" Height="401" Width="396">
    <Grid Margin="-9,0,-62,-74">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="43*"/>
            <ColumnDefinition Width="424*"/>
        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="/fff.jpg"/>
        </Grid.Background>
        <Label Content="Usuario" HorizontalAlignment="Left" Margin="31,81,0,0" VerticalAlignment="Top" FontFamily="Arial Black" FontSize="14" Grid.Column="1"/>
        <Label Content="Contraseña" HorizontalAlignment="Left" Margin="31,147,0,0" VerticalAlignment="Top" FontFamily="Arial Black" FontSize="14" Grid.Column="1"/>
        <TextBox HorizontalAlignment="Left" Margin="134,151,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120" Grid.Column="1"/>
        <TextBox HorizontalAlignment="Left" Margin="115,85,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120" Grid.Column="1"/>
        <Button Content="Iniciar Sesion" HorizontalAlignment="Left" Margin="80,226,0,0" VerticalAlignment="Top" Height="46" Width="168" Background="#FF1EA7D5" FontFamily="Arial Black" Grid.Column="1"/>
        <Button Content="Ir a Registro" HorizontalAlignment="Left" Margin="80,298,0,0" VerticalAlignment="Top" Height="46" Width="168" FontFamily="Arial Black" Background="#FFF4C325" Grid.Column="1"/>
        <Label Content="LOGIN" HorizontalAlignment="Left" Margin="128,10,0,0" VerticalAlignment="Top" FontFamily="Arial Black" FontSize="14" Grid.Column="1"/>

    </Grid>
</Window>
