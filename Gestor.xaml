<Page x:Class="ProyectoGym.Gestor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProyectoGym"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Gestor">

    <Grid Margin="0,0,422,-11" Background="White">
        <Label Content="Gestor Rutinas" HorizontalAlignment="Center" Margin="0,22,0,0" VerticalAlignment="Top" FontFamily="Arial Black" FontSize="14"/>
        <CheckBox Content="Rutina A" HorizontalAlignment="Left" Margin="127,104,0,0" VerticalAlignment="Top" FontSize="20" FontWeight="Bold"/>
        <CheckBox Content="Rutina B" HorizontalAlignment="Left" Margin="128,175,0,0" VerticalAlignment="Top" FontSize="20" FontWeight="Bold"/>
        <CheckBox Content="Full Body" HorizontalAlignment="Center" Margin="0,252,0,0" VerticalAlignment="Top" FontSize="20" FontWeight="Bold"/>
        <Button Content="CREAR RUTINA" HorizontalAlignment="Center" Margin="0,318,0,0" VerticalAlignment="Top" Background="#FF1EA7D5" FontSize="16" FontWeight="Bold" Height="47" Width="162"/>
        <Button Content="ELIMINAR RUTINA" HorizontalAlignment="Center" Margin="0,381,0,0" VerticalAlignment="Top" Height="47" Width="162" FontWeight="Bold" FontSize="14"/>
    </Grid>
</Page>
