<Page x:Class="ProyectoGym.Configuracion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ProyectoGym.ViewModel"
      Title="Configuracion">

    <Page.DataContext>
        <vm:ConfiguracionViewModel/>
    </Page.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFFAFAFA">
        <StackPanel Margin="40,20" MaxWidth="500">
            <TextBlock Text="PERSONALIZAR PERFIL"
                       FontFamily="Arial Black" FontSize="16"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>
            <TextBlock Text="Nivel de experiencia" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton Content="Novato"     IsChecked="{Binding EsNovato}"     FontSize="14" Margin="0,0,20,0"/>
                <RadioButton Content="Intermedio" IsChecked="{Binding EsIntermedio}" FontSize="14" Margin="0,0,20,0"/>
                <RadioButton Content="Avanzado"   IsChecked="{Binding EsAvanzado}"   FontSize="14"/>
            </StackPanel>
            <TextBlock Text="Objetivo principal" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <RadioButton Content="Ganar musculo" IsChecked="{Binding GanarMusculo}" FontSize="14" Margin="0,0,16,0"/>
                <RadioButton Content="Ganar fuerza"  IsChecked="{Binding GanarFuerza}"  FontSize="14" Margin="0,0,16,0"/>
                <RadioButton Content="Perder peso"   IsChecked="{Binding PerderPeso}"   FontSize="14"/>
            </StackPanel>
            <TextBlock Text="Equipamiento disponible" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <RadioButton Content="Completo"      IsChecked="{Binding EquipCompleto}"     FontSize="14" Margin="0,0,16,0"/>
                <RadioButton Content="Basico"        IsChecked="{Binding EquipBasico}"       FontSize="14" Margin="0,0,16,0"/>
                <RadioButton Content="Peso corporal" IsChecked="{Binding EquipPesoCorporal}" FontSize="14"/>
            </StackPanel>
            
            <TextBlock Text="Metricas" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Peso actual (kg)" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PesoActual, UpdateSourceTrigger=PropertyChanged}"
                             Height="32" Padding="8,4"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Peso meta (kg)" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PesoMeta, UpdateSourceTrigger=PropertyChanged}"
                             Height="32" Padding="8,4"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Altura (cm)" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Altura, UpdateSourceTrigger=PropertyChanged}"
                             Height="32" Padding="8,4"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding Mensaje}" Foreground="Green"
                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>

            <Button Content="GUARDAR CONFIGURACION"
                    Command="{Binding GuardarCommand}"
                    Height="48" FontFamily="Arial Black" FontSize="14"
                    Background="#FF1EA7D5" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
