<Page x:Class="ProyectoGym.Progreso"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ProyectoGym.ViewModel"
      Title="Progreso">

    <Page.DataContext>
        <vm:ProgresoViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PROGRESO"
                   FontFamily="Arial Black" FontSize="16"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <Border Grid.Row="1" Background="#FFDFDFE0" CornerRadius="8"
                Padding="16" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Peso corporal (kg)" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Peso, UpdateSourceTrigger=PropertyChanged}"
                             Width="110" Height="32" Padding="8,4"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Estado fisico" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EstadoFisico, UpdateSourceTrigger=PropertyChanged}"
                             Width="130" Height="32" Padding="8,4"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Rendimiento" FontWeight="Bold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Rendimiento, UpdateSourceTrigger=PropertyChanged}"
                             Width="130" Height="32" Padding="8,4"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <Button Content="GUARDAR PROGRESO"
                            Command="{Binding GuardarProgresoCommand}"
                            Height="44" Width="150" FontWeight="Bold"
                            Background="#FF1EA7D5" Foreground="White"
                            BorderThickness="0" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding Mensaje}" Foreground="Green" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Peso corporal" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox ItemsSource="{Binding HistorialPeso}" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                <TextBlock Text="Rendimiento" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox ItemsSource="{Binding HistorialRend}" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Estado fisico" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox ItemsSource="{Binding HistorialEstado}" FontSize="12"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
