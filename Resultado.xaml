<Page x:Class="ProyectoGym.Resultado"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ProyectoGym.ViewModel"
      Title="Resultados">

    <Page.DataContext>
        <vm:ResultadoViewModel/>
    </Page.DataContext>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="348*"/>
            <ColumnDefinition Width="205*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="RESULTADOS Y RESUMEN"
                   FontFamily="Arial Black" FontSize="16"
                   HorizontalAlignment="Left" Margin="161,0,0,16" Grid.ColumnSpan="2"/>
        <ListBox
                 ItemsSource="{Binding Resumen}"
                 FontSize="14" Padding="8"
                 Background="#FFF9F9F9"
                 BorderBrush="#FFDDDDDD" Margin="0,34,161,68" Grid.RowSpan="4" Grid.ColumnSpan="2"/>

        <Border Grid.Row="2" Background="#FFE8F5E9" CornerRadius="8"
                Padding="12" Margin="0,12,0,56"
                Visibility="{Binding RutinaGenerada,
                             Converter={StaticResource NullToVisibility}}" Grid.ColumnSpan="2" Grid.RowSpan="2">
            <TextBlock Text="{Binding RutinaGenerada}"
                       FontSize="13" FontFamily="Consolas"
                       TextWrapping="Wrap"/>
        </Border>

        <Button Grid.Row="3" Content="GENERAR RUTINA PERSONALIZADA"
                Command="{Binding GenerarRutinaCommand}"
                HorizontalAlignment="Left" Margin="246,30,0,-1" Width="260" FontFamily="Arial Black" FontSize="13"
                Background="#FF1EA7D5" Foreground="White" BorderThickness="0" Grid.ColumnSpan="2"/>
        <Button Content="Exportar a PDF" HorizontalAlignment="Right" Margin="0,30,200,0" Grid.Row="3" VerticalAlignment="Top" Background="#FFE82C2C" Foreground="White" FontWeight="Bold" Height="38" Width="148" Command="{Binding GenerarRutinaCommand}"/>
    </Grid>
</Page>
